              ]
            },
            {
              "command": "gobuster dir -u http://192.168.1.105 -w /usr/share/wordlists/dirbuster/directory-list-2.3-medium.txt -x php,html,txt,bak,old",
              "description": "Uzantı filtresiyle dosya keşfi",
              "tip": "CTF makinelerinde .php, .txt, .bak uzantıları kritik dosyaları gizler.",
              "flags": [
