          "title": "dir Modu — Dizin ve Dosya Keşfi",
          "commands": [
            {
              "command": "gobuster dir -u http://192.168.1.105 -w /usr/share/wordlists/dirb/common.txt",
              "description": "Temel dizin keşfi — common.txt wordlist ile",
              "output": "===============================================================\nGobuster v3.6\n===============================================================\n/admin                (Status: 301) [Size: 318]\n/images               (Status: 301) [Size: 320]\n/login                (Status: 200) [Size: 1524]\n/backup               (Status: 403) [Size: 291]\n/.htaccess            (Status: 403) [Size: 291]",
