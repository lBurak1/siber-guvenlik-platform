      "sections": [
        {
          "id": "commands",
          "type": "commands",
          "title": "Temel PowerShell Komutları",
          "commands": [
            {
              "command": "Get-ChildItem\n# Kısaltma: ls veya dir (alias olarak çalışır)",
              "description": "Mevcut dizindeki dosya ve klasörleri listele",
              "output": "    Directory: C:\\Users\\burak\n\nMode    LastWriteTime     Length Name\n----    -------------     ------ ----\nd----- 08.06.2026 10:00         Desktop\nd----- 08.06.2026 09:00         Documents\n-a---- 08.06.2026 08:15   1337  notlar.txt"
            },
            {
              "command": "Get-ChildItem -Hidden",
              "description": "Gizli dosyaları göster"
            },
            {
              "command": "Get-ChildItem -Recurse -Filter '*.txt'",
              "description": "Alt dizinlerde de .txt dosyalarını ara"
            },
            {
              "command": "Set-Location C:\\Users\\burak\\Desktop\n# Kısaltma: cd (alias)",
              "description": "Dizin değiştir"
            },
            {
              "command": "New-Item -ItemType Directory -Name 'pentest-notlar'",
              "description": "Yeni klasör oluştur"
            },
            {
              "command": "New-Item -ItemType File -Name 'notlar.txt'",
              "description": "Yeni boş dosya oluştur"
            },
            {
              "command": "New-Item -ItemType Directory -Force -Path 'CTF\\web\\sql'",
              "description": "İç içe dizin oluştur (-Force = varsa hata verme)"
            },
            {
              "command": "Get-Content notlar.txt\n# Kısaltma: cat (alias)",
              "description": "Dosya içeriğini oku"
            },
            {
              "command": "Get-Content C:\\Windows\\System32\\drivers\\etc\\hosts",
              "description": "hosts dosyasını oku (siber güvenlikte sık kullanılır)"
            },
            {
              "command": "Set-Content -Path notlar.txt -Value 'Merhaba PowerShell!'",
              "description": "Dosyaya içerik yaz (üstüne yazar)"
            },
            {
              "command": "Add-Content -Path notlar.txt -Value 'Yeni satır eklendi'",
              "description": "Dosyanın sonuna ekle (append)"
            },
            {
              "command": "Copy-Item dosya.txt -Destination C:\\Yedek\\",
              "description": "Dosyayı kopyala"
            },
            {
              "command": "Copy-Item -Recurse klasor\\ -Destination C:\\Yedek\\",
              "description": "Klasörü recursive kopyala"
            },
            {
              "command": "Move-Item dosya.txt -Destination C:\\Desktop\\",
              "description": "Taşı"
            },
            {
              "command": "Rename-Item dosya.txt -NewName yeni-dosya.txt",
              "description": "Yeniden adlandır"
            },
            {
              "command": "Remove-Item dosya.txt",
              "description": "Sil"
            },
            {
              "command": "Remove-Item -Recurse -Force klasor\\",
              "description": "Klasörü ve içeriğini sil"
            }
