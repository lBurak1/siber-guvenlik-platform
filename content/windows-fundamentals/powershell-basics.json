    {
      "id": "pipe-filtering",
      "title": "Pipe ve Filtreleme",
      "description": "Where-Object, Select-Object, Sort-Object, pipe zinciri",
      "difficulty": "intermediate",
      "duration": "15 dk",
      "sections": [
        {
          "id": "commands",
          "type": "commands",
          "title": "Pipe ve Filtreleme Komutları",
          "commands": [
            {
              "command": "Get-Process | Where-Object {$_.CPU -gt 10}",
              "description": "CPU kullanımı 10'dan fazla olan süreçleri filtrele",
              "tip": "$_ = pipe'dan gelen nesne (her eleman için). Like Linux'ta her satır için."
            },
            {
              "command": "Get-Service | Where-Object {$_.Status -eq 'Running'}",
              "description": "Çalışan servisleri filtrele"
            },
            {
              "command": "Get-ChildItem C:\\ -Recurse | Where-Object {$_.Length -gt 100MB}",
              "description": "100 MB'dan büyük dosyaları bul"
            },
            {
              "command": "Get-Process | Sort-Object CPU -Descending | Select-Object -First 10",
              "description": "CPU'ya göre sırala, en yüksek 10'u seç",
              "output": "Handles NPM(K) PM(K)  CPU(s)  Name\n------- ------ ------  ------  ----\n   1337    100  350000  45.2   chrome"
            },
            {
              "command": "Get-Process | Select-Object Name, CPU, WorkingSet",
              "description": "Sadece belirli özellikleri seç"
            },
            {
              "command": "Select-String -Path 'C:\\*.txt' -Pattern 'password'",
              "description": "Dosyalarda metin ara (Linux'ta grep gibi)",
              "output": "notlar.txt:5:password=admin123"
            },
            {
              "command": "Get-ChildItem -Recurse | Select-String -Pattern 'password'",
              "description": "Alt dizinlerde de arama"
            },
            {
              "command": "Get-Content access.log | Select-String '404' | Measure-Object",
              "description": "404 hata sayısını say"
            },
            {
              "command": "Get-Process | Format-Table Name, ID, CPU -AutoSize",
              "description": "Tablo formatında göster"
            },
            {
              "command": "Get-Service | Export-Csv -Path C:\\servisler.csv -NoTypeInformation",
              "description": "Çıktıyı CSV dosyasına aktar"
            }
          ]
        }
      ]
